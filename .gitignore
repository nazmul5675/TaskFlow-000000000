# TaskFlow — Git Ignore
# --------------------------------------------------------

# Database configuration (sensitive)
config/.env.php

# Operating System files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Environment files
.env
.env.local

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
tmp/
temp/
