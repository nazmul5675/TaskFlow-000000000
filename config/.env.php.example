<?php
/* =============================================================
   TaskFlow — Local / InfinityFree DB Credentials
   =============================================================
   Copy this file to config/.env.php and fill in your values.
   This file is loaded by config/db.php automatically.
   It is listed in .gitignore — NEVER commit real credentials.

   NOTE: On Railway, you do NOT need this file.
         Railway injects real environment variables (DB_HOST etc.)
         which db.php reads via getenv() before checking here.
   ============================================================= */

/* Database host
   Local XAMPP : 'localhost'
   InfinityFree: provided in your hosting control panel            */
define('DB_HOST', 'localhost');

/* Database port (usually 3306 — only change if host requires it) */
define('DB_PORT', 3306);

/* Database name
   Local XAMPP : whatever you created in phpMyAdmin
   InfinityFree: the auto-generated name in your cpanel           */
define('DB_NAME', 'taskflow_db');

/* Database username
   Local XAMPP : 'root'
   InfinityFree: the username shown in your cpanel                */
define('DB_USER', 'root');

/* Database password
   Local XAMPP : '' (empty string for default XAMPP install)
   InfinityFree: your cpanel DB password                          */
define('DB_PASS', '');
